# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Claude Code 로컬 워크트리(중첩 git 저장소)
.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files
.env*.local
.env
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/

# assets folder (엑셀 원본 파일)
/assets/
*.xlsx
*.xls
~$*.xlsx
~$*.xls

# uploads (기출문제 등)
/uploads

# mcp-bridge (별도 패키지)
/mcp-bridge/node_modules
/mcp-bridge/dist

# logs
*.log
watch.log

# 서술형 초안 (Claude Code 로컬 JSON)
.essay-drafts/
.essay-audit-logs/
.variant-drafts/
.essay-audit-reports/

# Audit 작업 중 자동 생성되는 일회성 패치 스크립트
scripts/patch-essay-*.ts

# 공유자료 — 자료 파일은 배포 환경에서 직접 업로드 (git 추적 X)
# 단, meta.json 과 .gitkeep 은 코드와 함께 관리해도 OK
/public/shared-resources/**
!/public/shared-resources/.gitkeep
!/public/shared-resources/*/meta.json
