# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Claude Code 로컬 워크트리(중첩 git 저장소)
.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files
.env*.local
.env
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/

# assets folder (엑셀 원본 파일)
# 디렉터리 자체는 추적 가능하게 두고 안의 내용물만 차단 — 그래야 exam_kit/ 만 예외 처리 가능.
/assets/**
# cc:essay CLI 가 읽는 템플릿/스타일은 git 추적.
!/assets/exam_kit/
!/assets/exam_kit/**
*.xlsx
*.xls
~$*.xlsx
~$*.xls

# uploads (기출문제 등)
/uploads

# mcp-bridge (별도 패키지)
/mcp-bridge/node_modules
/mcp-bridge/dist

# logs
*.log
watch.log

# 서술형 초안 (Claude Code 로컬 JSON)
.essay-drafts/
.essay-audit-logs/
.variant-drafts/
.essay-audit-reports/

# Audit 작업 중 자동 생성되는 일회성 패치 스크립트
scripts/patch-essay-*.ts

# 공유자료 — 자료 파일을 git 으로 직접 추적. Amplify Free Tier 안에서 운영.
# 회차 5~10개 누적되어 repo 부담 커지면 Cloudflare R2 등 외부 스토리지로 마이그레이션.
# OS 임시 파일·잠금 파일만 차단.
/public/shared-resources/**/.DS_Store
/public/shared-resources/**/~$*
