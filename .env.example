# MongoDB 연결 문자열 (Atlas 등)
# 로컬 테스트: 이 파일을 .env.local 로 복사한 뒤 실제 URI 로 채워주세요.
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

MONGODB_URI=

# Slack 알림 (선택) 주문 저장 시 해당 채널로 알림
# Slack 앱 → Incoming Webhooks → Webhook URL 복사
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
SLACK_WEBHOOK_URL=

# 관리자 세션 서명용 (선택, 기본값 있음) 배포 시 다른 값으로 설정 권장
# AUTH_SECRET=your-random-secret

# 회원가입문의 카카오톡 링크 (메인 메뉴 '회원가입문의' 클릭 시 이동)
# 예: 오픈채팅 https://open.kakao.com/o/xxxxx 또는 프로필 링크
# NEXT_PUBLIC_KAKAO_INQUIRY_URL=https://open.kakao.com/o/xxxxx
NEXT_PUBLIC_KAKAO_INQUIRY_URL=
