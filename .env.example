# MongoDB 연결 문자열 (Atlas 등)
# 로컬 테스트: 이 파일을 .env.local 로 복사한 뒤 실제 URI 로 채워주세요.
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

MONGODB_URI=

# Slack 알림 (선택) 주문 저장 시 해당 채널로 알림
# Slack 앱 → Incoming Webhooks → Webhook URL 복사
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
SLACK_WEBHOOK_URL=

# 주문서 하단 고객용 안내 문구 (선택). 설정하지 않으면 기본 문구가 붙습니다.
# ORDER_FOOTER_MESSAGE=주문해 주셔서 감사합니다.\n입금 확인 후 제작이 진행됩니다.\n문의: 카카오톡~
ORDER_FOOTER_MESSAGE=

# 관리자 세션 서명용 (선택, 기본값 있음) 배포 시 다른 값으로 설정 권장
# AUTH_SECRET=your-random-secret

# 관리자 계정 시드 (npm run seed:admin 시에만 사용, 코드에 노출되지 않음)
# 시드 후 관리자 로그인하여 비밀번호 변경 권장
# ADMIN_LOGIN_ID=admin
# ADMIN_INITIAL_PASSWORD=your-secure-password

# 공개 사이트 URL (프로덕션 권장). OG·metadataBase·푸터「고미조슈아 홈」에 사용. 슬래시 없이.
# NEXT_PUBLIC_SITE_URL=https://gomijoshua.com

# 카카오톡 문의 링크 (회원가입·상담 등 모든 문의 연결)
# NEXT_PUBLIC_KAKAO_INQUIRY_URL=https://open.kakao.com/o/sHuV7wSh
NEXT_PUBLIC_KAKAO_INQUIRY_URL=https://open.kakao.com/o/sHuV7wSh

# 푸터 사업자 정보 (선택, 퍼블릭 레포 노출 방지를 위해 env 권장)
# NEXT_PUBLIC_FOOTER_COMPANY_NAME=페이퍼릭 (Payperic)
# NEXT_PUBLIC_FOOTER_REP_NAME=대표자명
# NEXT_PUBLIC_FOOTER_BIZ_NUMBER=사업자등록번호
# NEXT_PUBLIC_FOOTER_ADDRESS=주소
# NEXT_PUBLIC_FOOTER_PHONE=전화번호

# ─── Claude AI (선택) ────────────────────────────────────────────────────
# /admin/generated-questions: 「풀기」, 새 변형문제「Claude로 초안 생성」, 「+ 같은유형」AI 초안
# https://console.anthropic.com/ 에서 API Key 발급
#
# ★ 배포(Vercel·Railway 등)에서 Claude가 안 될 때
#   1) 호스팅 대시보드 → Environment Variables 에 ANTHROPIC_API_KEY 추가
#      (.env.local 은 배포에 포함되지 않음 — 반드시 서버 환경 변수로 등록)
#      Production / Preview(미리보기) 모두 쓰면 미리보기 URL에서도 동작
#   2) Vercel Hobby(무료)는 서버리스 실행 시간이 짧아(약 10초) 긴 초안 생성이 끊길 수 있음
#      → Pro 이상이거나, 초안/풀기는 로컬(npm run dev)에서 실행
# Pro/Max(Claude Code·채팅)만 쓰고 API 별도 과금을 피하려면 비워 두고, 변형은 Code+MCP 저장·cc:variant 로만 작업
ANTHROPIC_API_KEY=
# 모델 ID는 콘솔·문서에서 확인 후 필요 시만 지정 (미설정 시 코드 기본값 사용)
# ANTHROPIC_SOLVE_MODEL=claude-sonnet-4-20250514
# AI 초안 출제 시 공통 지시 한 줄 (선택) — 초안 생성·from-sibling AI 모드 공통
# ANTHROPIC_VARIANT_DRAFT_EXTRA=
#
# ─── 변형문제 자동 생성 스케줄 (B) ───────────────────────────────────────
# 부족·미작성 분을 짠 뒤 Claude API로 초안 생성 → DB 저장(status 대기). Anthropic API 과금됨.
# POST /api/cron/variant-auto-fill
#   헤더: Authorization: Bearer <VARIANT_CRON_SECRET>  또는  x-variant-cron-secret: <동일값>
#   본문 JSON: { "textbook": "교재명" } 또는 { "orderId": "…" } 또는 { "orderNumber": "BV-…" }
#   선택: maxGenerations(기본 3, 상한 50), questionStatus(all|대기|완료), requiredPerType(숫자 문자열)
# 로컬·서버 cron: npm run variant:auto-fill -- --textbook "교재명" [--max 5] [--status all]
#   또는 --order-id <24hex>
# 선택 지연(연속 API 호출 간): VARIANT_AUTO_FILL_DELAY_MS=2000
# Vercel Hobby는 타임아웃이 짧아 다건 생성은 Pro·Railway 등 긴 실행 또는 로컬 cron 권장
# VARIANT_CRON_SECRET=

# 변형도 분석(/admin/generated-questions) 최대 스캔 건수 상한 (기본 80000, 최소 3000 · 최대 200000)
# ADMIN_VARIATION_MAX_SCAN=100000

# ─── Claude Code MCP 브리지 (선택) ───────────────────────────────────────
# 자동 설정: npm run mcp-bridge:setup  → .env.local 에 토큰·URL 없으면 추가
# 개발:      npm run dev:with-mcp      → Next + 브리지 동시 실행
# 관리 화면: /admin/mcp (관리자 로그인 후)
# 변형문제 모달「Claude로 초안 생성」: POST /api/admin/generated-questions/generate-draft (ANTHROPIC_API_KEY)
# 대기 문항 Claude Code 검수 로그: MongoDB gomijoshua.generated_question_claude_reviews · 화면 /admin/generated-questions/review-logs (조회 전용)
# 검수: Claude Code MCP variant_review_pending_list + variant_review_pending_record (npm run mcp:variant). DB만 사용, Anthropic API 없음.
# 웹 POST /review-run 은 항상 비활성(403).
#
# MCP_BRIDGE_URL=http://localhost:3100
# MCP_BRIDGE_TOKEN=(setup 스크립트가 생성)
# MCP_BRIDGE_PORT=3100
# MCP_BRIDGE_TIMEOUT=120000
# CLAUDE_PATH=claude
# MCP_BRIDGE_REPO_ROOT=/절대경로/next-order  (선택: claude mcp serve cwd, 기본은 자동 추정)
#
# 변형문제 전용 MCP 서버 (Claude Code에 stdio로 등록):
#   claude mcp add next-order-variant --scope project -- npm run mcp:variant
# 도구(요약): variant_list_textbooks, variant_list_passages, variant_get_passage, variant_get_shortage,
#   variant_generate_draft, variant_save_generated_question, variant_generate_and_save,
#   variant_review_pending_list, variant_review_pending_record
# MONGODB_URI 필수. variant_generate_* 는 ANTHROPIC_API_KEY. Claude가 직접 JSON 작성 후 save만 하면 API 키 불필요.
#
# MCP 없이 터미널만: npm run cc:variant -- textbooks | passages --textbook "…" | passage --id … | shortage … | save --json …
#   자세한 사용법: scripts/cc-variant-cli.ts 상단 주석

# ─── Dropbox 자동 폴더 생성 (선택) ────────────────────────────────────────
# 설정하면 새 주문 생성 시 Dropbox에 폴더를 자동으로 만듭니다.
# 구조: /{DROPBOX_ROOT_FOLDER}/{이름}_{loginId}/{주문번호}/
#
# 설정 방법:
#   1. https://www.dropbox.com/developers/apps 에서 앱 생성
#      - App type: Scoped access → Full Dropbox
#      - 권한(Permissions 탭): files.content.write, files.metadata.write 체크
#   2. App key, App secret 복사
#   3. 리프레시 토큰 발급 (한 번만):
#      https://www.dropbox.com/oauth2/authorize?client_id=<APP_KEY>&response_type=code&token_access_type=offline
#      → 브라우저에서 열어 승인 → code 값 복사
#      → curl -X POST https://api.dropbox.com/oauth2/token \
#           -d code=<CODE> -d grant_type=authorization_code \
#           -d redirect_uri=http://localhost \
#           -u <APP_KEY>:<APP_SECRET>
#      → 응답의 refresh_token 값을 아래에 입력
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
DROPBOX_ROOT_FOLDER=gomijoshua
# Dropbox 워크스페이스에서 '폴더 있음' 링크가 work/이름/앱/gomijoshua/... 형식일 때, 여기에 워크스페이스 이름(예: 박준규) 설정
# NEXT_PUBLIC_DROPBOX_WORK_SPACE=박준규

# ─── 학생 AI 쿼터 (선택, 기본값 있음) ────────────────────────────────────
# 학생 1인당 하루 AI 사용 횟수 (기본: 5)
STUDENT_AI_DAILY_LIMIT=5
# 학생 1인당 이번 주 AI 사용 횟수 (기본: 25)
STUDENT_AI_WEEKLY_LIMIT=25

# ─── 토스페이먼츠 — 포인트 충전 (/my → 「포인트 충전」) ───────────────────
# 개발자센터 https://developers.tosspayments.com/my/api-keys
#   - 결제창 연동: API 개별 연동 키 → 클라이언트 키(test_ck_… / live_ck_…)
#   - 시크릿 키(test_sk_… / live_sk_…)는 서버 전용, 절대 프론트·Git에 넣지 말 것
#
# 성공/실패 URL (코드에 고정): {사이트}/my/point-charge/success , …/fail
# 토스 대시보드 → 개발자센터 → URL 설정에 위 도메인 등록
#
# 권장 이름(아래) 또는 짧은 별칭(호스팅 UI에 이미 있을 때) 둘 중 하나만 채워도 됨.
NEXT_PUBLIC_TOSS_PAYMENTS_CLIENT_KEY=
# NEXT_PUBLIC_TOSS_CLIENT_KEY=   ← 위와 동일 역할(별칭)
TOSS_PAYMENTS_SECRET_KEY=
# TOSS_SECRET_KEY=               ← 위와 동일 역할(별칭)

# ─── 무통장 입금 계좌 (학생 신청 결제 안내에 노출) ──────────────────────
BANK_ACCOUNT_INFO=농협 000-0000-0000-00 예금주 OOO
NEXT_PUBLIC_BANK_ACCOUNT_INFO=농협 000-0000-0000-00 예금주 OOO
